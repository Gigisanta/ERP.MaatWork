# Frontend variables
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend variables
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Secret for Notion OAuth
JWT_SECRET=your_jwt_secret_here

# Notion CRM Configuration
VITE_NOTION_CRM_FALLBACK_URL=your_notion_fallback_url

# Notion OAuth Configuration
# Get these from https://www.notion.so/my-integrations
NOTION_CLIENT_ID=your_notion_client_id_here
NOTION_CLIENT_SECRET=your_notion_client_secret_here
NOTION_REDIRECT_URI=http://localhost:5173/notion-crm/callback
VITE_NOTION_REDIRECT_URI=http://localhost:5173/notion-crm/callback