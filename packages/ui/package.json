{
  "name": "@cactus/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Modern, accessible React component library built with Tailwind CSS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": {
      "require": "./dist/tailwind-preset.js",
      "import": "./dist/tailwind-preset.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && pnpm run build:styles && pnpm run build:link-styles && pnpm run build:add-use-client",
    "build:styles": "node scripts/copy-styles.js",
    "build:link-styles": "node scripts/link-styles.js",
    "build:add-use-client": "node scripts/add-use-client.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "typecheck": "pnpm run type-check"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.11.4",
    "clsx": "^2.0.0",
    "lucide-react": "^0.292.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@storybook/nextjs": "^8.5.3",
    "@storybook/react": "^8.5.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.6",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.6"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwind",
    "typescript",
    "accessibility"
  ],
  "author": "Cactus CRM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cactus-crm/cactus-dashboard.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/cactus-crm/cactus-dashboard/issues"
  },
  "homepage": "https://github.com/cactus-crm/cactus-dashboard#readme"
}
