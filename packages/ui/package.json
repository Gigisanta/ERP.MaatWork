{
  "name": "@cactus/ui",
  "version": "0.1.0",
  "description": "Modern, accessible React component library built with Tailwind CSS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles/index.css",
    "./styles.css": "./dist/styles/index.css",
    "./tailwind-preset": "./dist/tailwind-preset.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && pnpm run build:styles",
    "build:styles": "copyfiles -u 2 src/styles/**/*.css dist/styles",
    "dev": "echo 'UI package does not need dev mode'",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx --no-error-on-unmatched-pattern",
    "type-check": "tsc --noEmit",
    "typecheck": "pnpm run type-check"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.0.0",
    "lucide-react": "^0.263.1"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@types/jest": "^28.1.4",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "copyfiles": "^2.4.1",
    "jest": "^28.1.2",
    "jest-environment-jsdom": "^28.1.2",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "tailwind",
    "typescript",
    "accessibility"
  ],
  "author": "Cactus CRM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cactus-crm/cactus-dashboard.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/cactus-crm/cactus-dashboard/issues"
  },
  "homepage": "https://github.com/cactus-crm/cactus-dashboard#readme"
}
