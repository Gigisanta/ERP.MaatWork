{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2015", "ES2017", "ES2018", "ES2019", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // AI_DECISION: Habilitar incremental builds con cache persistente
    // Justificación: Incremental builds reducen tiempo de typecheck 15-25% en builds subsiguientes
    // Impacto: Typecheck más rápido, especialmente útil en desarrollo con cambios frecuentes
    "incremental": true,
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"]
  },
  "include": ["src/**/*", "src/tailwind-preset.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "exclude": [
    "node_modules", 
    "dist", 
    "tests", 
    "**/*.stories.tsx",
    "src/components/Select.tsx",
    "src/components/Switch.tsx",
    "src/components/nav/Header.tsx",
    "src/components/nav/Nav.tsx",
    "src/components/nav/Pagination.tsx",
    "src/components/nav/Sidebar.tsx"
  ]
}
