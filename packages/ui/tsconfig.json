{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // AI_DECISION: Disable exactOptionalPropertyTypes for UI package
    // Justification: UI components need to accept undefined from parent props without explicit undefined unions
    // Impact: Allows more flexible prop handling while maintaining other strict checks
    "exactOptionalPropertyTypes": false,
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // AI_DECISION: Habilitar incremental builds con cache persistente
    // Justificación: Incremental builds reducen tiempo de typecheck 15-25% en builds subsiguientes
    // Impacto: Typecheck más rápido, especialmente útil en desarrollo con cambios frecuentes
    "incremental": true,
    "tsBuildInfoFile": "tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest"]
  },
  "include": ["src/**/*", "src/tailwind-preset.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "exclude": [
    "node_modules", 
    "dist", 
    "tests", 
    "**/*.stories.tsx"
  ]
}
