{
  "name": "@maatwork/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "audit:code": "knip --workspace .",
    "generate": "drizzle-kit generate --config=drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.ts",
    "seed": "tsx src/seed.ts",
    "seed:all": "tsx src/seed-all.ts",
    "seed:pipeline": "tsx src/seed-pipeline-stages.ts",
    "seed:benchmarks": "tsx src/seed-benchmarks.ts",
    "seed:full": "tsx src/seed-full.ts",
    "seed:career-plan": "tsx src/seed-career-plan.ts",
    "seed:automations": "tsx src/seed-automations.ts",
    "partition:broker-transactions": "tsx scripts/partition-broker-transactions.ts",
    "db:init": "tsx src/seed-all.ts",
    "db:reset": "node reset-db.js",
    "db:reset-migrations": "node reset-migrations.js",
    "db:full-reset": "node full-reset.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "0.6.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.10.2",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
