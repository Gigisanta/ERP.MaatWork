{
  "name": "@cactus/db",
  "private": true,
  "version": "0.1.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "echo 'DB package does not need dev mode'",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx src/seed.ts",
    "seed:all": "tsx src/seed-all.ts",
    "seed:pipeline": "tsx src/seed-pipeline-stages.ts",
    "seed:benchmarks": "tsx src/seed-benchmarks.ts",
    "db:init": "tsx src/seed-all.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.24.0",
    "drizzle-orm": "^0.33.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/pg": "^8.10.2",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
