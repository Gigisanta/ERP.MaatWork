{
  "name": "@cactus/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate --config=drizzle.config.mjs",
    "migrate": "drizzle-kit migrate --config=drizzle.config.mjs",
    "studio": "drizzle-kit studio --config=drizzle.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx src/seed.ts",
    "seed:all": "tsx src/seed-all.ts",
    "seed:pipeline": "tsx src/seed-pipeline-stages.ts",
    "seed:benchmarks": "tsx src/seed-benchmarks.ts",
    "seed:full": "tsx src/seed-full.ts",
    "partition:broker-transactions": "tsx scripts/partition-broker-transactions.ts",
    "db:init": "tsx src/seed-all.ts",
    "db:reset": "node reset-db.js",
    "db:reset-migrations": "node reset-migrations.js",
    "db:full-reset": "node full-reset.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.38.4",
    "drizzle-zod": "^0.7.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.10.2",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
