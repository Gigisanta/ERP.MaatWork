{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "declaration": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "paths": {
            "@maatwork/types": ["../types/src/index.ts"],
            "@maatwork/types/*": ["../types/src/*"]
        }
    },
    "include": [
        "src/**/*"
    ]
}