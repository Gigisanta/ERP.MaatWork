{
  "name": "@maatwork/utils",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "default": "./dist/date.js"
    },
    "./career-plan": {
      "types": "./dist/career-plan.d.ts",
      "default": "./dist/career-plan.js"
    },
    "./circuit-breaker": {
      "types": "./dist/circuit-breaker.d.ts",
      "default": "./dist/circuit-breaker.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts src/date.ts src/career-plan.ts src/circuit-breaker.ts --format cjs,esm --dts",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "audit:code": "knip --workspace ."
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@maatwork/types": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
