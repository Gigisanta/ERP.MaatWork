## Patrones de CÃģdigo Obligatorios

### Backend: Estructura de Route Handler

```typescript
// apps/api/src/routes/[domain]/handlers/[action].ts
import { Router } from 'express';
import { z } from 'zod';
import { requireAuth } from '../../auth/middlewares';
import { validate } from '../../utils/validation';
import { createRouteHandler } from '../../utils/route-handler';

const router = Router();

// ==========================================================
// Zod Validation Schemas
// ==========================================================

const createSchema = z.object({
  name: z.string().min(1).max(100),
  email: z.string().email(),
});

// ==========================================================
// Routes
// ==========================================================

router.post('/',
  requireAuth,
  validate({ body: createSchema }),
  createRouteHandler(async (req) => {
    const result = await createItem(req.body);
    return result; // Respuesta automÃĄtica: { success: true, data: result }
  })
);

export default router;
```

### Frontend: Estructura de API Client

```typescript
// apps/web/lib/api/[domain].ts
import { apiClient } from '../api-client';
import type { ApiResponse } from '../api-client';

// ==========================================================
// Types
// ==========================================================

export interface CreateRequest { ... }
export interface UpdateRequest { ... }

// ==========================================================
// API Functions
// ==========================================================

export async function getItems(): Promise<ApiResponse<Item[]>> {
  return apiClient.get<Item[]>('/v1/items');
}

export async function createItem(data: CreateRequest): Promise<ApiResponse<Item>> {
  return apiClient.post<Item>('/v1/items', data);
}
```

### Frontend: Client Islands Pattern

```typescript
