# Configuración de pnpm para el workspace CactusDashboard
# Evita que pnpm busque workspaces en directorios padre

# Limitar búsqueda de workspaces al directorio actual
shamefully-hoist=true

# Configuración de linking
# Usando isolated para workspaces locales pero con configuración de webpack
# mejorada para resolver symlinks correctamente en monorepos
node-linker=isolated

# Configuración de resolución de módulos
# symlink=true permite que los paquetes se resuelvan correctamente
# IMPORTANTE: Con node-linker=isolated, los symlinks se crean en cada workspace
# individual (apps/*/node_modules/@cactus/*) y webpack necesita configuración
# especial para resolverlos correctamente
symlink=true

# Ignorar warnings de proyectos fuera del workspace
# (Los warnings de LM Studio, corepack, etc. se pueden ignorar)
loglevel=warn

# No buscar workspaces recursivamente fuera del directorio actual
# (Refuerza la configuración de pnpm-workspace.yaml)

