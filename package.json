{
  "name": "maatwork",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "build": "turbo run build",
    "build:api": "turbo build --filter=@maatwork/api",
    "build:web": "turbo build --filter=@maatwork/web",
    "build:clean": "turbo run build:clean && turbo run build",
    "setup": "tsx scripts/setup.js",
    "dev": "tsx scripts/cli/index.ts dev",
    "dev:fast": "tsx scripts/cli/index.ts dev --fast",
    "dev:basic": "turbo run dev --parallel",
    "dev:clean": "pnpm dev:kill && pnpm -F @maatwork/web clean && pnpm dev",
    "dev:kill": "pnpm mw clean dev --quiet",
    "lint": "turbo run lint",
    "lint:analytics": "cd apps/analytics-service && python -m flake8 . --max-line-length=88 --extend-ignore=E203,W503 && python -m mypy .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "node scripts/parallel-test-runner.mjs",
    "test:serial": "node scripts/generate-test-report.mjs",
    "test:full": "turbo run test",
    "test:report": "node scripts/generate-test-report.mjs",
    "test:watch": "turbo run test:watch",
    "test:ui": "turbo run test:unit -- --ui",
    "test:coverage": "turbo run test:coverage",
    "test:affected": "turbo run test:unit --filter=[HEAD^1]",
    "test:api": "pnpm -F @maatwork/api test",
    "test:web": "pnpm -F @maatwork/web test",
    "test:integration": "pnpm -F @maatwork/api test:integration",
    "test:e2e": "playwright test",
    "test:all": "pnpm test && pnpm test:integration && pnpm test:e2e",
    "test:e2e:full": "tsx scripts/setup-e2e-db-optimized.ts && playwright test",
    "test:e2e:setup": "tsx scripts/setup-e2e-db-optimized.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:performance": "echo 'Run performance tests with: k6 run apps/api/src/__tests__/performance/load/*.js'",
    "clean": "turbo run clean",
    "db:generate": "pnpm -F @maatwork/db run generate",
    "db:migrate": "pnpm -F @maatwork/db run migrate",
    "db:studio": "pnpm -F @maatwork/db run studio",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "lighthouse": "lhci autorun --config=lighthouserc.json",
    "predev": "pnpm mw clean dev --quiet",
    "predev:basic": "pnpm mw clean dev --quiet",
    "prepare": "husky install",
    "guard:artifacts": "pnpm mw audit artifacts",
    "health": "tsx scripts/cli/index.ts health",
    "gen": "tsx scripts/cli/index.ts gen",
    "verify:aum": "node scripts/verify-aum-import.js",
    "verify:aum:csv": "node scripts/verify-aum-csv-only.js",
    "test:aum:full": "node scripts/test-aum-import-full.js",
    "verify:all": "node scripts/verify-all.js",
    "verify:all:no-e2e": "SKIP_E2E=true node scripts/verify-all.js",
    "audit:code": "tsx scripts/cli/index.ts audit code",
    "audit:fix": "knip --fix",
    "audit:ci": "tsx scripts/cli/index.ts audit code --ci",
    "audit:types": "tsx scripts/cli/index.ts audit code",
    "audit:barrels": "tsx scripts/cli/index.ts audit code",
    "clean:temp": "node -e \"const fs=require('fs');['.tmp_aum_cookies.txt'].forEach(f=>{try{fs.unlinkSync(f);console.log('Deleted:',f)}catch(e){}})\"",
    "deps:outdated": "pnpm outdated",
    "deps:update": "pnpm mw deps update",
    "deps:update:major": "pnpm mw deps update --major",
    "deps:update:check": "pnpm mw deps update --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.58.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "chalk": "^4.1.2",
    "dotenv": "^16.6.1",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.0.11",
    "knip": "^5.81.0",
    "lint-staged": "^16.3.2",
    "pg": "^8.12.0",
    "prettier": "^3.7.4",
    "rimraf": "^5.0.10",
    "turbo": "^2.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "@types/react": "^19.2.2",
      "@types/react-dom": "^19.2.2",
      "typescript": "^5.9.3",
      "glob": ">=10.5.0",
      "js-yaml": ">=4.1.1",
      "tmp": ">=0.2.4",
      "esbuild": ">=0.25.0"
    },
    "@maatwork/validation": {
      "peerDependencies": {
        "zod": "^3.22.4"
      }
    }
  },
  "lint-staged": {
    "packages/ui/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "pnpm -F @maatwork/ui lint"
    ],
    "packages/ui/**/*.test.{ts,tsx}": "pnpm -F @maatwork/ui test",
    "apps/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
