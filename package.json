{
  "name": "@cactus/root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @cactus/web dev\" \"pnpm --filter @cactus/api dev\"",
    "dev:web": "pnpm --filter @cactus/web dev",
    "dev:api": "pnpm --filter @cactus/api dev",
    "build": "pnpm --filter @cactus/web build && pnpm --filter @cactus/api build",
    "build:web": "pnpm --filter @cactus/web build",
    "build:api": "pnpm --filter @cactus/api build",
    "test": "pnpm --recursive run test",
    "test:web": "pnpm --filter @cactus/web test",
    "lint": "pnpm --recursive run lint",
    "lint:fix": "pnpm --recursive run lint:fix",
    "check": "pnpm --recursive run check",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "seed:advisors": "node scripts/setup/create_advisors.js",
    "seed:advisors:admin": "node -r dotenv/config scripts/setup/create_advisors_admin.js",
    "seed:advisors:bulk": "node scripts/setup/create_advisors_bulk.js",
    "seed:test-user": "node scripts/setup/create_test_user.js",
    "check:auth": "node scripts/checks/check_auth_browser.js",
    "check:permissions": "node scripts/checks/check_permissions.cjs",
    "check:rls": "node scripts/checks/check_rls_status.js",
    "verify:db": "node scripts/checks/verify_database_production.js",
    "verify:roles": "node scripts/checks/verify_production_roles_system.js",
    "verify:advisors": "node scripts/checks/verify_advisors.js",
    "health": "node scripts/utils/health-check.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
