[railway]
# Railway will auto-detect services from monorepo structure

# Override the build command to build specific packages in order
[build]
command = "pnpm install --frozen-lockfile && pnpm -F @maatwork/types build && pnpm -F @maatwork/utils build && pnpm -F @maatwork/logger build && pnpm -F @maatwork/db build && pnpm -F @maatwork/api build && pnpm -F @maatwork/web build"

# Use Nixpacks (default)
builder = "NIXPACKS"

# Detect Node.js
buildPlan = "nixpacks"

[deploy]
# Wait for port to be ready
startupTimeout = 300

# Number of containers
numReplicas = 1
