{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Group monorepo packages together",
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "monorepo packages",
      "matchPackagePatterns": ["^@maatwork/"]
    },
    {
      "description": "Group TypeScript types together",
      "matchPackagePatterns": ["^@types/"],
      "groupName": "TypeScript types"
    },
    {
      "description": "Group ESLint packages together",
      "matchPackagePatterns": ["^eslint", "^@eslint/"],
      "groupName": "ESLint packages"
    },
    {
      "description": "Group testing packages together",
      "matchPackagePatterns": ["^@testing-library/", "^vitest", "^playwright"],
      "groupName": "Testing packages"
    },
    {
      "description": "Auto-merge patch and minor updates for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Auto-merge patch updates for production dependencies",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Pin dependencies",
      "matchDepTypes": ["dependencies"],
      "rangeStrategy": "pin"
    }
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": ["before 6am on monday"],
  "timezone": "America/Argentina/Buenos_Aires",
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}} to {{newVersion}}",
  "commitMessageExtra": "",
  "separateMinorPatch": true,
  "separateMajorMinor": true,
  "ignoreDeps": [],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  }
}








