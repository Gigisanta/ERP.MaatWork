{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "project": [
    "apps/**/*.{ts,tsx}",
    "packages/**/*.{ts,tsx}",
    "scripts/**/*.{ts,js}",
    "tests/**/*.{ts,tsx}"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.d.ts",
    "**/dist/**",
    "**/.next/**",
    "**/node_modules/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/migrations/**",
    "**/__pycache__/**",
    "apps/analytics-service/**"
  ],
  "ignoreDependencies": [
    "@types/*",
    "eslint*",
    "@typescript-eslint/*",
    "prettier",
    "vitest",
    "@vitest/*",
    "playwright",
    "@playwright/*",
    "turbo",
    "husky",
    "lint-staged",
    "@changesets/*",
    "@lhci/*",
    "rimraf",
    "chalk",
    "tsx",
    "pino-pretty",
    "pg",
    "@types/pg"
  ],
  "ignoreBinaries": ["python", "tsx", "test:coverage:check", "pm2"],
  "workspaces": {
    "apps/api": {
      "entry": ["src/index.ts", "src/routes/**/index.ts"]
    },
    "apps/web": {
      "entry": [
        "app/**/page.tsx",
        "app/**/layout.tsx",
        "app/**/loading.tsx",
        "app/**/error.tsx",
        "middleware.ts",
        "next.config.js"
      ]
    },
    "packages/ui": {
      "entry": ["src/index.ts", "src/components/**/index.ts"]
    },
    "packages/db": {
      "entry": ["src/index.ts", "src/schema/*.ts", "scripts/**/*.ts"]
    },
    "packages/types": {
      "entry": ["src/index.ts"]
    }
  }
}
