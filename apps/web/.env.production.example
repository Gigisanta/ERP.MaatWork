# AI_DECISION: .env.production.example actualizado para Railway
# Justificación: Variables públicas del frontend necesarias para Railway
# Impacto: NEXT_PUBLIC_* variables disponibles en el navegador para API calls
# Referencias: Railway environment variable management
#
# =================================================================
# MAATWORK WEB - Production Environment Configuration (Railway)
# =================================================================
# INSTRUCCIONES:
# 1. En Railway, configurar estas variables en el dashboard del servicio
# 2. Las variables NEXT_PUBLIC_* se incluyen en el bundle del cliente
# 3. Las demas variables solo estan disponibles en el servidor
# =================================================================

# =================================================================
# BUILD-TIME VARIABLES (NEXT_PUBLIC_*)
# Estas se incluyen en el bundle de JavaScript del cliente
# =================================================================

# URL de la API - DEBE ser accesible desde el navegador del usuario
# Si usas proxy reverso en /api, incluir el path
NEXT_PUBLIC_API_URL=https://maat.work/api

# Google OAuth Client ID - Para el boton de "Sign in with Google"
# En Railway: Usar Railway reference: ${{maatwork-api.RAILWAY_PUBLIC_DOMAIN}}/api (si el cliente esta en el mismo dominio)
# O configurar directamente el valor del Google Cloud Console
NEXT_PUBLIC_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# JWT Secret - CRITICO: Debe coincidir con el del API para que el middleware funcione
JWT_SECRET=secreto-largo-y-seguro-copiar-desde-api

# =================================================================
# RUNTIME-ONLY VARIABLES (Server Components)
# Estas NO se incluyen en el bundle, solo disponibles en servidor
# =================================================================

# URL interna de la API - Para Server Components que evitan Cloudflare
# Usar localhost si la API esta en el mismo servidor
API_URL_INTERNAL=http://localhost:3001

# =================================================================
# NEXT.JS CONFIGURATION
# =================================================================

# Permitir optimizacion de imagenes desde estos dominios
NEXT_PUBLIC_IMAGE_DOMAINS=maat.work,lh3.googleusercontent.com

# =================================================================
# VERIFICACION
# =================================================================
# Despues del build, verificar que las variables estan incluidas:
#   grep -r "NEXT_PUBLIC_API_URL" .next/static
# Deberia mostrar la URL de produccion, NO localhost

# =================================================================
# CONFIGURACION RAILWAY ESPECIFICA
# =================================================================
#
# 1. Variables compartidas entre servicios Railway:
#    - DATABASE_URL: Referenciar desde servicio PostgreSQL
#    - API_URL: Referenciar desde servicio API (dominio público)
#    - JWT_SECRET: Compartir con servicio API para validacion de tokens
#
# 2. Variables de servicio Railway:
#    ${{postgres-service.RAILWAY_PUBLIC_DOMAIN}} - Dominio de PostgreSQL
#    ${{api-service.RAILWAY_PUBLIC_DOMAIN}} - Dominio público de API
#    ${{api-service.RAILWAY_PRIVATE_DOMAIN}} - Dominio interno para llamadas server-to-server
#
# 3. Health checks Railway:
#    - API: /health (debe retornar 200 OK)
#    - Web: /api/health (debe retornar 200 OK)
#
# =================================================================
# MIGRACION DESDE AWS
# =================================================================
# Cambios principales desde AWS (ECS/RDS) a Railway:
# - Eliminar: CDN_URL, configuración Cloudflare específica
# - Actualizar: API_URL a referencias Railway internas
# - Agregar: Variables Railway-specific para comunicación inter-servicio
# - Mantener: JWT_SECRET compartido entre API y Web
#