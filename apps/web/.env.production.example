# =================================================================
# MAATWORK WEB - Production Environment Configuration
# =================================================================
# INSTRUCCIONES:
# 1. Copiar este archivo a .env antes de hacer build
# 2. Las variables NEXT_PUBLIC_* se incluyen en el bundle del cliente
# 3. Las demas variables solo estan disponibles en el servidor
# =================================================================

# =================================================================
# BUILD-TIME VARIABLES (NEXT_PUBLIC_*)
# Estas se incluyen en el bundle de JavaScript del cliente
# =================================================================

# URL de la API - DEBE ser accesible desde el navegador del usuario
# Si usas proxy reverso en /api, incluir el path
NEXT_PUBLIC_API_URL=https://maat.work/api

# Google OAuth Client ID - Para el boton de "Sign in with Google"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=[TU_CLIENT_ID].apps.googleusercontent.com

# JWT Secret - CRITICO: Debe coincidir con el del API para que el middleware funcione
JWT_SECRET=secreto-largo-y-seguro-copiar-desde-api

# =================================================================
# RUNTIME-ONLY VARIABLES (Server Components)
# Estas NO se incluyen en el bundle, solo disponibles en servidor
# =================================================================

# URL interna de la API - Para Server Components que evitan Cloudflare
# Usar localhost si la API esta en el mismo servidor
API_URL_INTERNAL=http://localhost:3001

# =================================================================
# NEXT.JS CONFIGURATION
# =================================================================

# Permitir optimizacion de imagenes desde estos dominios
NEXT_PUBLIC_IMAGE_DOMAINS=maat.work,lh3.googleusercontent.com

# =================================================================
# VERIFICACION
# =================================================================
# Despues del build, verificar que las variables estan incluidas:
#   grep -r "NEXT_PUBLIC_API_URL" .next/static
# Deberia mostrar la URL de produccion, NO localhost
