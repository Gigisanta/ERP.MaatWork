# ==============================================
# CACTUS WEB - Environment Variables
# ==============================================

# API URL (must be accessible from browser)
# Local: http://localhost:3001
# Production: http://YOUR_IP_OR_DOMAIN/api
NEXT_PUBLIC_API_URL=http://localhost:3001

# Disable Vercel Analytics when not on Vercel (self-hosted)
# Set to 'false' for self-hosted deployments
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# JWT Secret for middleware authentication
# IMPORTANT: Must match the JWT_SECRET in apps/api/.env
# This is used by Next.js middleware to validate session cookies
# In development: use 'dev-insecure-secret-change-me' (matches API default)
JWT_SECRET=dev-insecure-secret-change-me

# Internal API URL for Server Components (PRODUCTION ONLY)
# Server Components call the API directly without going through Cloudflare
# This avoids Cloudflare's "Just a moment..." challenge on server-to-server requests
# Leave unset in development (defaults to NEXT_PUBLIC_API_URL)
# API_URL_INTERNAL=http://127.0.0.1:3001

# ==============================================
# PRODUCTION NOTES (self-hosted with PM2 + Nginx)
# ==============================================
# 1. Create .env.production.local with production values
# 2. NEXT_PUBLIC_* vars must be set BEFORE 'next build'
# 3. Example build command:
#    NEXT_PUBLIC_API_URL=http://YOUR_IP/api \
#    NEXT_PUBLIC_ENABLE_ANALYTICS=false \
#    NODE_ENV=production npx next build
# 
# 4. Nginx must pass these headers for redirects to work:
#    proxy_set_header X-Forwarded-Host $host;
#    proxy_set_header X-Forwarded-Proto $scheme;
