{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    // AI_DECISION: Habilitar incremental builds con cache persistente
    // Justificación: Incremental builds reducen tiempo de typecheck 15-25% en builds subsiguientes
    // Impacto: Typecheck más rápido, especialmente útil en desarrollo con cambios frecuentes
    "incremental": true,
    "tsBuildInfoFile": ".next/tsconfig.tsbuildinfo",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/types": ["./types/index.ts"],
      "@/types/*": ["./types/*"],
      "@/lib/*": ["./lib/*"],
      "@/lib/api": ["./lib/api/index.ts"],
      "@/lib/api/*": ["./lib/api/*"],
      "@/components/*": ["./app/components/*"],
      "@cactus/ui": ["../../packages/ui/dist/index.d.ts"]
    },
    "baseUrl": "."
  },
  "include": ["next-env.d.ts", "vitest.d.ts", "types/**/*.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "vitest.setup.ts", "vitest.config.ts"]
}
