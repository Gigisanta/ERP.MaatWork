NODE_ENV=development
PORT=3001
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cactus

# Comma-separated origins. In production, only these will be allowed.
CORS_ORIGINS=http://localhost:3000

# Enable Helmet CSP (optional). If 'true', Helmet usará la CSP por defecto.
CSP_ENABLED=false


