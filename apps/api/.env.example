# ==============================================
# CACTUS API - Environment Variables
# ==============================================

# Environment
NODE_ENV=development

# Server
PORT=3001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/CRM

# Security
# JWT secret for token signing (REQUIRED in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-insecure-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Helmet CSP (Content Security Policy)
# Enable in production with proper policy
CSP_ENABLED=false

# ==============================================
# Python Analytics Service
# ==============================================
# URL of the Python analytics microservice
PYTHON_SERVICE_URL=http://localhost:3002

# ==============================================
# Timeouts (Optional - defaults provided)
# ==============================================
# All values in milliseconds

# Portfolio performance timeout (default: 60000ms = 60s)
# PORTFOLIO_PERFORMANCE_TIMEOUT=60000

# Portfolio comparison base timeout (default: 30000ms = 30s)
# PORTFOLIO_COMPARE_BASE_TIMEOUT=30000

# Additional timeout per portfolio/benchmark in comparison (default: 5000ms = 5s)
# PORTFOLIO_COMPARE_PER_ITEM_TIMEOUT=5000

# Maximum timeout for portfolio comparison (default: 120000ms = 120s)
# PORTFOLIO_COMPARE_MAX_TIMEOUT=120000

# Python service request timeout (default: 30000ms = 30s)
# PYTHON_SERVICE_TIMEOUT=30000

# Instrument search timeout (default: 10000ms = 10s)
# INSTRUMENT_SEARCH_TIMEOUT=10000

# Price backfill timeout (default: 300000ms = 5min)
# PRICE_BACKFILL_TIMEOUT=300000

# ==============================================
# AUM Upload Configuration
# ==============================================
# Directory for file uploads (runtime files, NOT test fixtures)
# Default: ./uploads (development) or /var/app/uploads (production)
UPLOAD_DIR=./uploads

# Enable/disable pg_trgm extension for fuzzy text matching
# Set to false if extension is not available in your database
PG_TRGM_ENABLED=true