{
  "name": "@cactus/api",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "LOG_LEVEL=debug tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "add-user": "tsx src/add-user.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pm2:logrotate:install": "pm2 install pm2-logrotate",
    "pm2:logrotate:config": "pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 10 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:dateFormat YYYY-MM-DD_HH-mm-ss && pm2 set pm2-logrotate:workerInterval 60 && pm2 set pm2-logrotate:rotateInterval 0 0 * * *"
  },
  "dependencies": {
    "@cactus/db": "workspace:*",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.33.0",
    "express": "^5.1.0",
    "helmet": "^7.1.0",
    "jose": "^5.2.4",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "node-fetch": "^3.3.2",
    "pg": "^8.12.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.2",
    "jest": "^29.7.0",
    "pino-pretty": "^11.3.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
