{
  "name": "@cactus/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:pretty": "cross-env NODE_ENV=development tsx watch src/index.ts | pino-pretty",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "add-user": "tsx src/add-user.ts",
    "add-advisors": "tsx src/add-advisors.ts",
    "assign-unassigned-contacts": "tsx src/scripts/assign-unassigned-contacts.ts",
    "verify-contacts-assignment": "tsx src/scripts/verify-contacts-assignment.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pm2:logrotate:install": "pm2 install pm2-logrotate",
    "pm2:logrotate:config": "pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 10 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:dateFormat YYYY-MM-DD_HH-mm-ss && pm2 set pm2-logrotate:workerInterval 60 && pm2 set pm2-logrotate:rotateInterval 0 0 * * *"
  },
  "dependencies": {
    "@cactus/db": "workspace:*",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jose": "^5.2.4",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "pino": "^8.16.0",
    "pino-http": "^8.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.9.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.6",
    "cross-env": "^7.0.3",
    "eslint": "^8.53.0",
    "pino-pretty": "^10.2.3",
    "supertest": "^7.1.4",
    "tsx": "^4.1.0",
    "typescript": "^5.2.2",
    "vitest": "^4.0.6"
  }
}
