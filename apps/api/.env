# ========================================
# CONFIGURACIÓN DEL SISTEMA DE COMPARACIÓN MENSUAL
# ========================================

# Base de datos PostgreSQL (PRODUCCIÓN AWS)
# ⚠️ REEMPLAZA con tu endpoint de RDS o base de datos de producción
# Formato: postgresql://usuario:password@host:5432/nombre_db
# Ejemplo RDS: postgresql://maatwork_user:password@maatwork-db.abc123.us-east-1.rds.amazonaws.com:5432/CRM
DATABASE_URL=postgresql://cactus_admin:7V8PcCEvH9LFAzfHbLGqCDhUmaBNHPQS@cactus-mvp-dev-databaseb269d8bb-s5qrpp48ux92.c5oaie0qy73q.sa-east-1.rds.amazonaws.com:5432/cactus

# Puerto del servidor API (PM2 usa 127.0.0.1, Nginx hace el proxy)
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ========================================
# CONFIGURACIÓN DE ARCHIVOS
# ========================================

# Tamaño máximo de archivos (en bytes)
MAX_FILE_SIZE=104857600  # 100MB

# Extensiones permitidas (separadas por comas)
ALLOWED_EXTENSIONS=.xlsx,.xls, .csv

# ========================================
# CONFIGURACIÓN DE COMPARACIÓN MENSUAL
# ========================================

# Tamaño máximo específico para comparación mensual
COMPARACION_MENSUAL_MAX_FILE_SIZE=104857600  # 100MB

# Porcentaje para warning de registros sin asesor
COMPARACION_MENSUAL_WARNING_SIN_ASESOR_PERCENT=50

# Tamaño de lote para procesamiento
COMPARACION_MENSUAL_BATCH_SIZE=1000

# Timeout para procesamiento (en ms)
COMPARACION_MENSUAL_TIMEOUT=300000  # 5 minutos

# ========================================
# CONFIGURACIÓN DE SNAPSHOTS
# ========================================

# Días de retención de snapshots
SNAPSHOT_RETENTION_DAYS=365

# Habilitar verificación de integridad
ENABLE_SNAPSHOT_INTEGRITY_CHECK=true

# ========================================
# CONFIGURACIÓN DE AUDITORÍA
# ========================================

# Habilitar logging de auditoría
ENABLE_AUDIT_LOGGING=true

# Nivel de log para auditoría
AUDIT_LOG_LEVEL=info

# ========================================
# CONFIGURACIÓN DE EXPORTACIÓN
# ========================================

# Máximo de registros para exportación
EXPORT_MAX_RECORDS=100000

# Incluir metadatos en exportación
EXPORT_INCLUDE_METADATA=true

# ========================================
# CONFIGURACIÓN DE UI
# ========================================

# Paginación por defecto
UI_PAGINATION_DEFAULT=100

# Máximo de paginación
UI_PAGINATION_MAX=1000

# Mostrar warnings en UI
UI_SHOW_WARNINGS=true

# Requerir confirmación para cambios críticos
UI_CONFIRMATION_REQUIRED=true

# ========================================
# CONFIGURACIÓN DE PERFORMANCE
# ========================================

# Habilitar índices optimizados
ENABLE_OPTIMIZED_INDEXES=true

# Cache de consultas frecuentes
ENABLE_QUERY_CACHE=true

# ========================================
# CONFIGURACIÓN DE SEGURIDAD
# ========================================

# Secret para firmar tokens JWT (debe ser único y seguro en producción)
JWT_SECRET=dev-insecure-secret-change-me

# Habilitar validación estricta
ENABLE_STRICT_VALIDATION=true

# Requerir autenticación para operaciones críticas
REQUIRE_AUTH_FOR_CRITICAL_OPERATIONS=true

# ========================================
# CONFIGURACIÓN DE GOOGLE OAUTH2
# ========================================

# Google OAuth2 Client ID
GOOGLE_CLIENT_ID=641908288178-937m4kvthd9m6jh59n3dg561bira535l.apps.googleusercontent.com

# Google OAuth2 Client Secret
GOOGLE_CLIENT_SECRET=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

# Google OAuth2 Redirect URI (PRODUCCIÓN)
# ⚠️ DEBE coincidir con la configuración en Google Cloud Console
# ⚠️ REEMPLAZA con tu dominio de producción
GOOGLE_REDIRECT_URI=https://maat.work/v1/auth/google/callback

# Clave de encriptación para tokens OAuth (32+ caracteres, requerido para AES-256-GCM)
# ⚠️ Este es el mismo que tenías - verifica que sea seguro
GOOGLE_ENCRYPTION_KEY=99e998c952441e3abd3fd0d9729ec73a0af3e7c35e1abf969b3f77787d0fd5eb

# URL del frontend para redirects de OAuth (PRODUCCIÓN)
# ⚠️ REEMPLAZA con tu dominio de producción
FRONTEND_URL=https://maat.work

# ========================================
# CONFIGURACIÓN DE CORS (PRODUCCIÓN)
# ========================================

# Orígenes permitidos para CORS (separados por comas)
# ⚠️ REEMPLAZA con tu(s) dominio(s) de producción
CORS_ORIGINS=https://maat.work,https://www.maat.work

# Dominio para cookies (permite cookies en subdominios)
# ⚠️ REEMPLAZA con tu dominio (con punto inicial para subdominios)
COOKIE_DOMAIN=.maat.work

























