{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@cactus/db": ["../../packages/db/src/index.ts"],
      "@cactus/db/*": ["../../packages/db/src/*"],
      "@cactus/ui": ["../../packages/ui/src/index.ts"],
      "@cactus/ui/*": ["../../packages/ui/src/*"]
    },
    "types": ["node"],
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "node_modules", "dist"]
}


