# =================================================================
# MAATWORK API - Production Environment Configuration
# =================================================================
# INSTRUCCIONES:
# 1. Copiar este archivo a .env en el servidor de produccion
# 2. Reemplazar TODOS los valores marcados con [REQUERIDO]
# 3. Verificar que todos los dominios apunten a maat.work
# =================================================================

# Core Configuration
NODE_ENV=production
PORT=3001
HOST=127.0.0.1

# Database (PostgreSQL)
# [REQUERIDO] Reemplazar con credenciales reales
DATABASE_URL=postgresql://maatwork_user:[PASSWORD]@localhost:5432/maatwork_production

# Authentication (JWT)
# [REQUERIDO] Generar con: openssl rand -hex 32
JWT_SECRET=[GENERAR_SECRETO_SEGURO_DE_32_CHARS_MINIMO]
JWT_EXPIRES_IN=7d

# =================================================================
# CONFIGURACION CRITICA PARA CLOUDFLARE
# =================================================================

# CORS - Origenes permitidos (separados por coma, sin espacios)
# [REQUERIDO] Incluir todos los dominios del frontend
CORS_ORIGINS=https://maat.work,https://www.maat.work

# Frontend URL - Para redirects de OAuth
# [REQUERIDO] URL base del frontend
FRONTEND_URL=https://maat.work

# Cookie Domain - Para que cookies funcionen con subdominios
# [REQUERIDO] Debe empezar con punto para incluir subdominios
COOKIE_DOMAIN=.maat.work

# =================================================================
# GOOGLE OAUTH2
# =================================================================
# Configurar en: https://console.cloud.google.com/apis/credentials

# [REQUERIDO] Credenciales de Google OAuth
GOOGLE_CLIENT_ID=[TU_CLIENT_ID].apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[TU_CLIENT_SECRET]

# [REQUERIDO] URI de callback - DEBE coincidir con lo configurado en Google Console
# NOTA: Si usas proxy reverso en /api, la ruta cambia
GOOGLE_REDIRECT_URI=https://maat.work/api/v1/auth/google/callback

# [REQUERIDO] Clave para encriptar refresh tokens - Generar con: openssl rand -hex 16
GOOGLE_ENCRYPTION_KEY=[GENERAR_CLAVE_DE_32_CHARS]

# =================================================================
# LOGGING
# =================================================================
LOG_LEVEL=info
# CSP headers (opcional, para reportes de seguridad)
CSP_ENABLED=true

# =================================================================
# N8N WEBHOOKS (Opcional - Automatizaciones)
# =================================================================
N8N_ENABLED=true
N8N_WEBHOOK_RATE_LIMIT=60
N8N_WEBHOOK_BATCH_SIZE=100
N8N_WEBHOOK_TIMEOUT=30000

# =================================================================
# VERIFICACION
# =================================================================
# Antes de iniciar la API, ejecutar:
#   node -e "require('./dist/config/env.js')"
# Si hay errores, revisar las variables marcadas como [REQUERIDO]
