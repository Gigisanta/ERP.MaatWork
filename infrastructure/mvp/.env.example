# =============================================================================
# Cactus MVP - Variables de Entorno para Producción
# =============================================================================
# Copia este archivo a .env y completa los valores
# NO commitear el archivo .env al repositorio
# =============================================================================

# Base de datos (obtener de AWS Secrets Manager)
# Formato: postgresql://usuario:password@host:5432/database
DATABASE_URL=postgresql://cactus_admin:PASSWORD@RDS_ENDPOINT:5432/cactus

# JWT Secret (generar con: openssl rand -base64 32)
JWT_SECRET=tu-jwt-secret-aqui

# URL pública de la API (para el frontend)
# Usar la IP elástica o dominio cuando esté configurado
NEXT_PUBLIC_API_URL=http://TU_IP_O_DOMINIO/api

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=*

# Nivel de logging (debug, info, warn, error)
LOG_LEVEL=info

# =============================================================================
# Para obtener las credenciales de la DB desde AWS:
# aws secretsmanager get-secret-value \
#   --secret-id cactus-dev/db-credentials \
#   --region sa-east-1 \
#   --query SecretString \
#   --output text
# =============================================================================

