# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files
# Note: terraform.tfvars in environments/* are committed as templates
# Real secrets should go in .env files
.env
!.env.example

# Override tfvars (use for local overrides)
*.auto.tfvars

# CLI configuration files
.terraformrc
terraform.rc

# Generated import scripts
import_*.sh


