# =============================================================================
# Terraform S3 Backend Configuration
# =============================================================================
#
# Copy this file to your environment directory and rename to backend.tf
# Update the key path for each environment (dev/prod)
#
# Before using, create the S3 bucket and DynamoDB table:
#
#   aws s3 mb s3://cactus-terraform-state --region us-east-1
#
#   aws dynamodb create-table \
#     --table-name cactus-terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST \
#     --region us-east-1
#
# =============================================================================

terraform {
  backend "s3" {
    bucket         = "cactus-terraform-state"
    key            = "dev/terraform.tfstate"  # Change to "prod/terraform.tfstate" for prod
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "cactus-terraform-locks"
  }
}




