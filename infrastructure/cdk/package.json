{
  "name": "cactus-infrastructure",
  "version": "2.0.0",
  "private": true,
  "description": "Cactus CRM Infrastructure - AWS CDK",
  "scripts": {
    "cdk": "cdk",
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "deploy:mvp:dev": "cdk deploy --all --context mode=mvp --context env=dev --require-approval never",
    "deploy:mvp:prod": "cdk deploy --all --context mode=mvp --context env=prod --require-approval broadening",
    "deploy:adv:dev": "cdk deploy --all --context mode=advanced --context env=dev --require-approval never",
    "deploy:adv:prod": "cdk deploy --all --context mode=advanced --context env=prod --require-approval broadening",
    "diff:mvp:dev": "cdk diff --context mode=mvp --context env=dev",
    "diff:mvp:prod": "cdk diff --context mode=mvp --context env=prod",
    "diff:adv:dev": "cdk diff --context mode=advanced --context env=dev",
    "diff:adv:prod": "cdk diff --context mode=advanced --context env=prod",
    "destroy:mvp:dev": "cdk destroy --all --context mode=mvp --context env=dev --force",
    "destroy:mvp:prod": "cdk destroy --all --context mode=mvp --context env=prod",
    "destroy:adv:dev": "cdk destroy --all --context mode=advanced --context env=dev --force",
    "destroy:adv:prod": "cdk destroy --all --context mode=advanced --context env=prod",
    "synth:mvp:dev": "cdk synth --context mode=mvp --context env=dev",
    "synth:mvp:prod": "cdk synth --context mode=mvp --context env=prod",
    "synth:adv:dev": "cdk synth --context mode=advanced --context env=dev",
    "synth:adv:prod": "cdk synth --context mode=advanced --context env=prod"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.158.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "aws-cdk": "^2.158.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
