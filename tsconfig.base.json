{
  "compilerOptions": {
    "target": "ES2022",
    // AI_DECISION: Use ESNext module for ES module support across the monorepo
    // Justification: Packages use import.meta and other ES module features
    // Impact: Enables proper type checking for ES module code
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@maatwork/db": ["packages/db/src/index.ts"],
      "@maatwork/db/*": ["packages/db/src/*"],
      "@maatwork/ui": ["packages/ui/src/index.ts"],
      "@maatwork/ui/*": ["packages/ui/src/*"],
      "@maatwork/types": ["packages/types/src/index.ts"],
      "@maatwork/types/*": ["packages/types/src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  }
}
