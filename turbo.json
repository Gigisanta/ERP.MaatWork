{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**"
      ],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "app/**/*.tsx",
        "package.json",
        "tsconfig.json"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "app/**/*.tsx",
        "package.json",
        "tsconfig.json"
      ]
    },
    "build:clean": {
      "dependsOn": ["^build:clean"],
      "outputs": [
        "dist/**",
        ".next/**"
      ],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "app/**/*.tsx",
        "package.json",
        "tsconfig.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        ".eslintrc.*",
        "package.json"
      ]
    },
    "test": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "vitest.config.*",
        "package.json"
      ]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "**/*.test.ts",
        "**/*.test.tsx",
        "vitest.config.*",
        "package.json"
      ],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.stories.tsx",
        "package.json"
      ]
    }
  }
}


